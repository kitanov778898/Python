    <datasourcesManager ClassName="LimeReport::DataSourceManager" Type="Object">
      <objectName Type="QString">datasources</objectName>
      <connections Type="Collection">
        <item ClassName="LimeReport::ConnectionDesc" Type="Object">
          <objectName Type="QString"></objectName>
          <name Type="QString">qt_sql_default_connection</name>
          <driver Type="QString">QMYSQL3</driver>
          <databaseName Type="QString">lims_server</databaseName>
          <userName Type="QString">report</userName>
          <password Type="QString" Value="NqWi6z+oAbjELx7IIkX89Q=="/>
          <host Type="QString">10.36.0.61</host>
          <autoconnect Type="bool" Value="1"/>
          <keepDBCredentials Type="bool" Value="1"/>
          <port Type="int" Value="-1"/>
        </item>
      </connections>
      <queries Type="Collection">
        <item ClassName="LimeReport::QueryDesc" Type="Object">
          <objectName Type="QString"></objectName>
          <queryName Type="QString">журнал</queryName>
          <queryText Type="QString">SELECT @count:=@count+1 AS 'Годовой номер', temp_table_2.* FROM
 (
 SELECT
 ohl1.order_id AS 'заказ', (SELECT @count:= (SELECT count(*) FROM
 (
 SELECT o1.id FROM orders_has_labtests as ohl1
 JOIN orders AS o1 ON o1.id = ohl1.order_id
 JOIN testresults AS tr1 ON tr1.id = ohl1.testresult_id
 WHERE tr1.object_id in ( 38 ) #Указать лаборатории для которых строится журнал
 AND tr1.validationtime > UNIX_TIMESTAMP(STR_TO_DATE("01.01."$V{year}" 00:00", '%d.%m.%Y %H:%i'))
 AND tr1.validationtime &lt; UNIX_TIMESTAMP(STR_TO_DATE($V{startdate}, '%d.%m.%Y %H:%i'))
 AND ohl1.labtest_id IN ( 1344,1404,1405,2066,385 )    #Перечислить тесты
  and tr1.defected = 0
and tr1.normstate_id not in (2)
 GROUP BY o1.id) AS temp_table_1)) AS 'вычисление_гн',
 from_unixtime(tr1.validationtime, "%d.%m.%Y") AS 'Дата утверждения результата',
 concat(p1.secondname, ' ', substr(p1.firstname, 1, 1), '.', substr(p1.middlename, 1, 1), '.')  AS 'ФИО', d1.kod AS  'Диагноз',
 DATE_FORMAT(DATE_ADD(FROM_UNIXTIME(0), interval p1.birthday second),'%d.%m.%Y') AS 'Дата рождения',
 # --- 1.) --- 388, РМП ---
 group_concat(distinct(case when ohl1.labtest_id=1344 then tr1.result end)) AS 'Выявление Core - антигена вируса гепатита С ',
 group_concat(distinct(case when ohl1.labtest_id=1344 then tr1.normstate_id end)) AS 'Выявление Core - антигена вируса гепатита С _статус',
  group_concat(distinct(case when ohl1.labtest_id=1404 then tr1.result end)) AS 'HbsAg вируса гепатита B ',
 group_concat(distinct(case when ohl1.labtest_id=1404 then tr1.normstate_id end)) AS 'HbsAg вируса гепатита B _статус',
  group_concat(distinct(case when ohl1.labtest_id=1405 then tr1.result end)) AS 'АТ к вирусу гепатита C',
 group_concat(distinct(case when ohl1.labtest_id=1405 then tr1.normstate_id end)) AS 'АТ к вирусу гепатита C_статус',
  group_concat(distinct(case when ohl1.labtest_id=2066 then tr1.result end)) AS 'АТ IgG к вирусу гепатита С',
 group_concat(distinct(case when ohl1.labtest_id=2066 then tr1.normstate_id end)) AS 'АТ IgG к вирусу гепатита С_статус',
   group_concat(distinct(case when ohl1.labtest_id=385 then tr1.result end)) AS 'Трепонема  M, G',
 group_concat(distinct(case when ohl1.labtest_id=385 then tr1.normstate_id end)) AS 'Трепонема  M, G_статус',
 u1.secondname AS 'Направил', u2.secondname AS 'Утвердил'
 FROM orders_has_labtests AS ohl1
 JOIN orders AS o1 ON ohl1.order_id = o1.id
 JOIN testresults AS tr1 ON ohl1.testresult_id = tr1.id
 JOIN patients AS p1 ON o1.patient_id = p1.id
 JOIN users AS u1 ON u1.id = o1.user_id
 JOIN users AS u2 ON u2.id = tr1.validator_id
 lEFT JOIN diagnoses AS d1 ON d1.name = o1.diagnoses
 WHERE tr1.object_id in ( 38 ) #Указать лабораторию переменная labs_id
 AND tr1.validationtime > UNIX_TIMESTAMP(STR_TO_DATE($V{startdate}, "%d.%m.%Y %H:%i"))
 AND tr1.validationtime &lt; UNIX_TIMESTAMP(STR_TO_DATE($V{stopdate}, '%d.%m.%Y %H:%i'))
 AND ohl1.labtest_id IN ( 1344,1404,1405,2066,385 ) #Указать лаборатории для которых строится журнал
and tr1.normstate_id not in (2)
 and tr1.defected = 0
 GROUP BY ohl1.order_id
 ORDER BY tr1.validationtime ASC) AS temp_table_2;</queryText>
