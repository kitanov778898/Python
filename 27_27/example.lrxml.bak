      <initScript Type="QString">Dialog.dateTimeEdit.date=new Date();
Dialog.dateTimeEdit_2.date=new Date();
var result = Dialog.exec()==1
if (result){
  setVariable("startdate",Dialog.dateTimeEdit.text);
  setVariable("year",Dialog.dateTimeEdit.text.substr(6,4));
  setVariable("stopdate",Dialog.dateTimeEdit_2.text);
  setVariable("startpage",Dialog.spinBox.text);
  setVariable("isChecked",Dialog.checkBox.checked)
if (Dialog.checkBox.checked) {Reportpage2.printable = true} else {Reportpage2.printable = false}
}
result</initScript>
