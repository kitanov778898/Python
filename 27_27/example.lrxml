    <datasourcesManager Type="Object" ClassName="LimeReport::DataSourceManager">
      <objectName Type="QString">datasources</objectName>
      <connections Type="Collection">
        <item Type="Object" ClassName="LimeReport::ConnectionDesc">
          <objectName Type="QString"></objectName>
          <name Type="QString">qt_sql_default_connection</name>
          <driver Type="QString">QMYSQL3</driver>
          <databaseName Type="QString">lims_server</databaseName>
          <userName Type="QString">report</userName>
          <password Type="QString" Value="7y3B01LjQ3Q="/>
          <host Type="QString">10.148.10.110</host>
          <autoconnect Type="bool" Value="1"/>
          <keepDBCredentials Type="bool" Value="1"/>
          <port Type="int" Value="-1"/>
        </item>
      </connections>
      <queries Type="Collection">
        <item Type="Object" ClassName="LimeReport::QueryDesc">
          <objectName Type="QString"></objectName>
          <queryName Type="QString">журнал</queryName>
          <queryText Type="QString">SELECT
    ohl1.order_id AS 'заказ',
    FROM_UNIXTIME(tr1.validationtime, "%d.%m.%Y") AS 'Дата утверждения результата',
    CONCAT(p1.secondname, ' ', SUBSTR(p1.firstname, 1, 1), '.', SUBSTR(p1.middlename, 1, 1), '.') AS 'ФИО',
   ifnull((select d.name from order_diagnoses od join diagnoses d on od.diagnosis_id = d.id where od.order_id = o1.id and od.diagnose_nosology_id=1), o1.diagnoses) AS 'Диагноз',
    DATE_FORMAT(DATE_ADD(FROM_UNIXTIME(0), INTERVAL p1.birthday SECOND), '%d.%m.%Y') AS 'Дата рождения',
    dep.NAME_FULL AS 'Откуда',
    -- --- Тесты ---
    GROUP_CONCAT(DISTINCT CASE WHEN ohl1.labtest_id = 801 THEN tr1.result END) AS 'Антиген системы KEL',
    GROUP_CONCAT(DISTINCT CASE WHEN ohl1.labtest_id = 801 THEN tr1.normstate_id END) AS 'Антиген системы KEL_статус',
    GROUP_CONCAT(DISTINCT CASE WHEN ohl1.labtest_id = 1507 THEN tr1.result END) AS 'C',
    GROUP_CONCAT(DISTINCT CASE WHEN ohl1.labtest_id = 1507 THEN tr1.normstate_id END) AS 'C_статус',
    GROUP_CONCAT(DISTINCT CASE WHEN ohl1.labtest_id = 1508 THEN tr1.result END) AS '_c_',
    GROUP_CONCAT(DISTINCT CASE WHEN ohl1.labtest_id = 1508 THEN tr1.normstate_id END) AS '_c_статус',
    GROUP_CONCAT(DISTINCT CASE WHEN ohl1.labtest_id = 1509 THEN tr1.result END) AS 'E',
    GROUP_CONCAT(DISTINCT CASE WHEN ohl1.labtest_id = 1509 THEN tr1.normstate_id END) AS 'E_статус',
    GROUP_CONCAT(DISTINCT CASE WHEN ohl1.labtest_id = 1510 THEN tr1.result END) AS '_e_',
    GROUP_CONCAT(DISTINCT CASE WHEN ohl1.labtest_id = 1510 THEN tr1.normstate_id END) AS '_e_статус',
    GROUP_CONCAT(DISTINCT CASE WHEN ohl1.labtest_id = 1511 THEN tr1.result END) AS 'k',
    GROUP_CONCAT(DISTINCT CASE WHEN ohl1.labtest_id = 1511 THEN tr1.normstate_id END) AS 'k_статус',
    GROUP_CONCAT(DISTINCT CASE WHEN ohl1.labtest_id = 1512 THEN tr1.result END) AS 'Антиэритроцитарные антитела',
    GROUP_CONCAT(DISTINCT CASE WHEN ohl1.labtest_id = 1512 THEN tr1.normstate_id END) AS 'Антиэритроцитарные антитела_статус',
    GROUP_CONCAT(DISTINCT CASE WHEN ohl1.labtest_id = 798 THEN tr1.result END) AS 'AB0',
    GROUP_CONCAT(DISTINCT CASE WHEN ohl1.labtest_id = 798 THEN tr1.normstate_id END) AS 'AB0_статус',
    GROUP_CONCAT(DISTINCT CASE WHEN ohl1.labtest_id = 799 THEN tr1.result END) AS 'Резус-фактор',
    GROUP_CONCAT(DISTINCT CASE WHEN ohl1.labtest_id = 799 THEN tr1.normstate_id END) AS 'Резус-фактор_статус',
    u1.secondname AS 'Направил',
    u2.secondname AS 'Утвердил'
FROM orders_has_labtests AS ohl1
JOIN orders AS o1 ON ohl1.order_id = o1.id
JOIN testresults AS tr1 ON ohl1.testresult_id = tr1.id
JOIN patients AS p1 ON o1.patient_id = p1.id
JOIN users AS u1 ON u1.id = o1.user_id
JOIN users AS u2 ON u2.id = tr1.validator_id
JOIN objects dep ON o1.department_id = dep.id
LEFT JOIN diagnoses AS d1 ON d1.name = o1.diagnoses
WHERE tr1.object_id IN (44) -- Указать лабораторию переменная labs_id
  AND tr1.validationtime > UNIX_TIMESTAMP(STR_TO_DATE($V{startdate}, '%d.%m.%Y %H:%i'))
  AND tr1.validationtime &lt; UNIX_TIMESTAMP(STR_TO_DATE($V{stopdate}, '%d.%m.%Y %H:%i'))
  AND ohl1.labtest_id IN (801, 1507, 1508, 1509, 1510, 1511, 1512, 798, 799) -- Новые тесты
  AND tr1.defected = 0
GROUP BY ohl1.order_id
ORDER BY tr1.validationtime ASC;</queryText>
          <connectionName Type="QString">qt_sql_default_connection</connectionName>
        </item>
      </queries>
      <subqueries Type="Collection"/>
      <subproxies Type="Collection"/>
      <variables Type="Collection">
        <item Type="Object" ClassName="LimeReport::VarDesc">
          <objectName Type="QString"></objectName>
          <name Type="QString">startdate</name>
          <value Type="QString">14.04.2025 0:00</value>
          <isMandatory Type="bool" Value="0"/>
          <dataType Type="int" Value="0"/>
        </item>
        <item Type="Object" ClassName="LimeReport::VarDesc">
